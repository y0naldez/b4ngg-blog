---
const path = Astro.url.pathname;

let targetPath = '/en/';
let label = 'EN';

if (path.startsWith('/en')) {
	targetPath = path.replace(/^\/en/, '') || '/';
	label = 'ES';
} else {
	targetPath = `/en${path}`;
	label = 'EN';
}
---

<a class="language-switch" href={targetPath} aria-label="Cambiar idioma">
	{label}
</a>

<style>
	.language-switch {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.4rem;
		padding: 0 0.85rem;
		border-radius: 999px;
		border: 1px solid rgb(var(--gray-light));
		background: var(--surface);
		color: rgb(var(--gray-dark));
		font-size: 0.9rem;
		font-weight: 800;
		text-decoration: none;
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.language-switch:hover {
		color: var(--accent);
		border-color: var(--accent);
		transform: translateY(-1px);
	}
</style>