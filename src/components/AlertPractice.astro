---

<section class="alert-practice" data-alert-practice>
	<div class="practice-header">
		<div class="score-box" data-score>Progreso: 0 / {alerts.length}</div>
	</div>

	<div class="carousel-shell">
		<div class="carousel-status">
			<span data-carousel-position>Pregunta 1 / {alerts.length}</span>
			<div class="progress-track" aria-hidden="true">
				<span data-progress-bar style={`width: ${100 / alerts.length}%`}></span>
			</div>
		</div>

		<div class="alerts-carousel" data-carousel>
			{
				alerts.map((alert, index) => (
					<article
						class:list={['alert-card', index === 0 && 'is-active']}
						data-alert-card
						data-alert-id={alert.id}
						data-correct={alert.correct}
						hidden={index !== 0}
					>
						<div class="alert-card-header">
							<span class="alert-number">{alert.code}</span>
							<h3>{alert.title}</h3>
						</div>

						<div class="options" role="radiogroup" aria-label={`Clasificacion para ${alert.code}`}>
							<label>
								<input
									type="radio"
									name={`alert-${alert.id}`}
									value="true"
									data-option
								/>
								True Positive
							</label>

							<label>
								<input
									type="radio"
									name={`alert-${alert.id}`}
									value="false"
									data-option
								/>
								False Positive
							</label>
						</div>

						<div class="actions">
							<button type="button" class="check-button" data-check>
								Validar respuesta
							</button>

							<button type="button" class="reset-button" data-reset>
								Reiniciar
							</button>
						</div>

						<p class="result-message" data-result hidden></p>

						<details class="explanation-box" data-explanation hidden>
							<summary>Ver explicacion y evidencia</summary>

							<div class="explanation-content">
								<strong>Explicacion:</strong>
								<p>{alert.explanation}</p>

								<strong>KQL recomendado:</strong>
								<pre><code>{alert.kql}</code></pre>

								<strong>Eventos relacionados:</strong>
								<p>{alert.events}</p>
							</div>
						</details>
					</article>
				))
			}
		</div>

		<div class="carousel-controls" aria-label="Controles del carrusel">
			<button type="button" class="nav-button" data-prev aria-label="Pregunta anterior">
				<span aria-hidden="true">&larr;</span>
				Anterior
			</button>

			<div class="dot-list" data-dot-list aria-label="Seleccionar pregunta">
				{
					alerts.map((alert, index) => (
						<button
							type="button"
							class:list={['dot-button', index === 0 && 'is-active']}
							data-dot={index}
							aria-label={`Ir a pregunta ${alert.id}`}
							aria-current={index === 0 ? 'step' : undefined}
						>
							{alert.id}
						</button>
					))
				}
			</div>

			<button type="button" class="nav-button" data-next aria-label="Pregunta siguiente">
				Siguiente
				<span aria-hidden="true">&rarr;</span>
			</button>
		</div>
	</div>
</section>

<script>
	const practiceSections = document.querySelectorAll('[data-alert-practice]');

	practiceSections.forEach((section) => {
		const cards = Array.from(section.querySelectorAll('[data-alert-card]'));
		const scoreBox = section.querySelector('[data-score]');
		const positionBox = section.querySelector('[data-carousel-position]');
		const progressBar = section.querySelector('[data-progress-bar]');
		const prevButton = section.querySelector('[data-prev]');
		const nextButton = section.querySelector('[data-next]');
		const dots = Array.from(section.querySelectorAll('[data-dot]'));
		let currentIndex = 0;

		function updateScore() {
			const completed = cards.filter((card) => card.dataset.completed === 'true').length;

			if (scoreBox) {
				scoreBox.textContent = `Progreso: ${completed} / ${cards.length}`;
			}
		}

		function showCard(index) {
			currentIndex = Math.max(0, Math.min(index, cards.length - 1));

			cards.forEach((card, cardIndex) => {
				const isActive = cardIndex === currentIndex;
				card.hidden = !isActive;
				card.classList.toggle('is-active', isActive);
			});

			dots.forEach((dot, dotIndex) => {
				const isActive = dotIndex === currentIndex;
				dot.classList.toggle('is-active', isActive);
				dot.setAttribute('aria-current', isActive ? 'step' : 'false');
			});

			if (positionBox) {
				positionBox.textContent = `Pregunta ${currentIndex + 1} / ${cards.length}`;
			}

			if (progressBar) {
				progressBar.style.width = `${((currentIndex + 1) / cards.length) * 100}%`;
			}

			if (prevButton) {
				prevButton.disabled = currentIndex === 0;
			}

			if (nextButton) {
				nextButton.disabled = currentIndex === cards.length - 1;
			}
		}

		cards.forEach((card) => {
			const alertId = card.dataset.alertId;
			const correctAnswer = card.dataset.correct;
			const checkButton = card.querySelector('[data-check]');
			const resetButton = card.querySelector('[data-reset]');
			const result = card.querySelector('[data-result]');
			const explanation = card.querySelector('[data-explanation]');
			const options = Array.from(card.querySelectorAll('[data-option]'));
			const storageKey = `aurelius-alert-${alertId}`;
			const savedAnswer = localStorage.getItem(storageKey);

			if (savedAnswer) {
				const savedOption = card.querySelector(`input[value="${savedAnswer}"]`);

				if (savedOption) {
					savedOption.checked = true;
				}
			}

			checkButton?.addEventListener('click', () => {
				const selected = card.querySelector('input[type="radio"]:checked');

				if (!selected) {
					if (result) {
						result.hidden = false;
						result.textContent =
							'Selecciona True Positive o False Positive antes de validar.';
						result.className = 'result-message warning';
					}

					if (explanation) {
						explanation.hidden = true;
					}

					return;
				}

				localStorage.setItem(storageKey, selected.value);
				card.dataset.completed = 'true';

				const isCorrect = selected.value === correctAnswer;

				if (result) {
					result.hidden = false;
					result.textContent = isCorrect
						? 'Correcto.'
						: 'Incorrecto. Revisa la explicacion.';
					result.className = isCorrect
						? 'result-message correct'
						: 'result-message incorrect';
				}

				if (explanation) {
					explanation.hidden = false;
					explanation.open = false;
				}

				options.forEach((option) => {
					option.disabled = true;
				});

				updateScore();
			});

			resetButton?.addEventListener('click', () => {
				localStorage.removeItem(storageKey);
				card.dataset.completed = 'false';

				options.forEach((option) => {
					option.checked = false;
					option.disabled = false;
				});

				if (result) {
					result.hidden = true;
					result.textContent = '';
					result.className = 'result-message';
				}

				if (explanation) {
					explanation.hidden = true;
					explanation.open = false;
				}

				updateScore();
			});
		});

		prevButton?.addEventListener('click', () => {
			showCard(currentIndex - 1);
		});

		nextButton?.addEventListener('click', () => {
			showCard(currentIndex + 1);
		});

		dots.forEach((dot) => {
			dot.addEventListener('click', () => {
				showCard(Number(dot.dataset.dot));
			});
		});

		section.addEventListener('keydown', (event) => {
			if (event.key === 'ArrowLeft') {
				showCard(currentIndex - 1);
			}

			if (event.key === 'ArrowRight') {
				showCard(currentIndex + 1);
			}
		});

		updateScore();
		showCard(0);
	});
</script>

<style>
	.alert-practice {
		margin-top: 2rem;
	}

	.alert-practice [hidden] {
		display: none !important;
	}

	.practice-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.practice-header h2 {
		margin: 0;
	}

	.practice-header p {
		margin-bottom: 0;
	}

	.eyebrow {
		margin: 0 0 0.35rem;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
		opacity: 0.7;
	}

	.score-box {
		flex: 0 0 auto;
		padding: 0.5rem 0.75rem;
		border: 1px solid rgba(148, 163, 184, 0.5);
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 700;
	}

	.carousel-shell {
		display: grid;
		gap: 1rem;
	}

	.carousel-status {
		display: grid;
		gap: 0.5rem;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.progress-track {
		overflow: hidden;
		width: 100%;
		height: 0.55rem;
		border-radius: 8px;
		background: rgba(148, 163, 184, 0.2);
	}

	.progress-track span {
		display: block;
		height: 100%;
		border-radius: inherit;
		background: #38bdf8;
		transition: width 180ms ease;
	}

	.alerts-carousel {
		position: relative;
		min-height: 18rem;
	}

	.alert-card {
		border: 1px solid rgba(148, 163, 184, 0.35);
		border-radius: 8px;
		padding: 1rem;
		background: rgba(15, 23, 42, 0.04);
	}

	.alert-card.is-active {
