---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.lang === 'en')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

		<style>
			main {
				width: min(100% - 2rem, 1100px);
				margin: 0 auto;
				padding: 3rem 1rem 4rem;
			}

			.blog-header {
				margin-bottom: 2.5rem;
				padding: 2.5rem 2rem;
				text-align: center;
				background: color-mix(in srgb, var(--surface) 82%, transparent);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 24px;
				box-shadow: var(--box-shadow);
			}

			.badge {
				display: inline-block;
				margin-bottom: 1rem;
				padding: 0.35rem 0.8rem;
				border-radius: 999px;
				background: color-mix(in srgb, var(--accent) 18%, transparent);
				color: var(--accent-dark);
				font-size: 0.85rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.blog-header h1 {
				margin: 0 0 1rem;
				font-size: clamp(2.2rem, 6vw, 3.5rem);
				line-height: 1;
				letter-spacing: -0.06em;
			}

			.blog-header p {
				max-width: 720px;
				margin: 0 auto;
				color: rgb(var(--gray));
				font-size: 1.05rem;
				line-height: 1.7;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.posts-grid.single-post {
				max-width: 620px;
				margin: 0 auto;
				grid-template-columns: 1fr;
			}

			.posts-grid.single-post .post-content {
				padding: 1.4rem;
			}

			.posts-grid.single-post .title {
				font-size: 1.5rem;
			}

			.post-card {
				height: 100%;
				overflow: hidden;
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 18px;
				box-shadow: 0 12px 34px rgba(0, 0, 0, 0.12);
				transition:
					transform 0.2s ease,
					border-color 0.2s ease,
					box-shadow 0.2s ease;
			}

			.post-card:hover {
				transform: translateY(-4px);
				border-color: color-mix(in srgb, var(--accent) 55%, rgb(var(--gray-light)));
				box-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
			}

			.post-card a {
				display: flex;
				flex-direction: column;
				height: 100%;
				color: inherit;
				text-decoration: none;
			}

			.post-image {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				background: rgb(var(--gray-light));
			}

			.post-image img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform 0.25s ease;
			}

			.post-card:hover .post-image img {
				transform: scale(1.04);
			}

			.post-content {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				padding: 1.2rem;
			}

			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.35rem;
				line-height: 1.2;
				letter-spacing: -0.03em;
			}

			.description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.98rem;
				line-height: 1.6;
			}

			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				font-weight: 700;
			}

			.empty-state {
				padding: 2rem;
				text-align: center;
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 18px;
			}

			@media (max-width: 720px) {
				main {
					width: 100%;
					padding: 1.5rem 1rem 3rem;
				}

				.blog-header {
					padding: 2rem 1.25rem;
				}

				.posts-grid.single-post {
					max-width: 100%;
				}

				.posts-grid.single-post .title {
					font-size: 1.35rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>

			{
				posts.length > 0 ? (
					<ul class:list={['posts-grid', { 'single-post': posts.length === 1 }]}>
						{posts.map((post) => (
							<li class="post-card">
								<a href={`/en/blog/${post.id.replace(/^en\//, '')}/`}>
									{post.data.heroImage && (
										<div class="post-image">
											<Image
												width={520}
												height={293}
												src={post.data.heroImage}
												alt={post.data.title}
											/>
										</div>
									)}

									<div class="post-content">
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>

										<h2 class="title">{post.data.title}</h2>

										<p class="description">{post.data.description}</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				) : (
					<div class="empty-state">
						<p>No English posts have been published yet.</p>
					</div>
				)
			}
		</main>

		<Footer />
	</body>
</html>