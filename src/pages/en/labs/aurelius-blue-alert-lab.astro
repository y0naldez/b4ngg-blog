---
import BlogPost from '../../../layouts/BlogPost.astro';
import AlertPractice from '../../../components/AlertPracticeEn.astro';
import cjcaBlueImage from '../../../assets/cjca_blue.png';

const page = {
	title: 'Aurelius Blue Alert Lab: Alert Practice',
	description:
		'Practice classifying alerts as True Positive or False Positive using the Aurelius Blue Alert Lab.',
	pubDate: new Date('2026-06-26T12:00:00-06:00'),
	heroImage: cjcaBlueImage,
	lang: 'en',
};
---

<BlogPost {...page}>
	<p>
		In this section, you can practice classifying alerts from the lab.
		Mark each alert as <strong>True Positive</strong> or
		<strong>False Positive</strong>, then check your answer.
	</p>

	<hr class="section-divider" />

	<AlertPractice />
</BlogPost>

<style>
	.section-divider {
		margin: 2rem 0;
		border: 0;
		border-top: 1px solid rgba(148, 163, 184, 0.35);
	}
</style>